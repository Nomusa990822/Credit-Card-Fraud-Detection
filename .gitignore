# =========================
# PYTHON
# =========================
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =========================
# VIRTUAL ENVIRONMENTS
# =========================
.venv/
venv/
env/
ENV/

# =========================
# JUPYTER
# =========================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =========================
# DATA (DO NOT TRACK RAW OR GENERATED DATA)
# =========================
data/raw/
data/interim/
data/processed/

# Optional: allow small sample datasets
# !data/raw/sample.csv

# =========================
# MODEL FILES
# =========================
models/*.pkl
models/*.joblib
models/*.h5
models/*.onnx

# =========================
# ARTIFACTS / OUTPUTS
# =========================
artifacts/*
!artifacts/.gitkeep

# Reports (generated outputs)
reports/figures/
reports/tables/
reports/*.pdf

# =========================
# SQL / DATABASE FILES
# =========================
*.db
*.sqlite
*.sqlite3
*.duckdb

# Optional SQL outputs (generated CSVs)
artifacts/sql_outputs/

# =========================
# LOGS
# =========================
logs/
*.log

# =========================
# CACHE / TEMP FILES
# =========================
.cache/
.tmp/
temp/
*.tmp

# =========================
# ENVIRONMENT VARIABLES
# =========================
.env
.env.*
*.env

# =========================
# KAGGLE / API KEYS
# =========================
kaggle.json

# =========================
# IDE / EDITOR FILES
# =========================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# =========================
# OS FILES
# =========================
.DS_Store
Thumbs.db

# =========================
# PYTEST
# =========================
.pytest_cache/
coverage.xml
htmlcov/

# =========================
# MISC
# =========================
*.bak
*.swp
*.swo

# =========================
# NOTEBOOK EXPORTS
# =========================
*.html
*.pdf

# =========================
# KEEP IMPORTANT STRUCTURE
# =========================
!artifacts/.gitkeep
